# Database - PostgreSQL (Neon, Supabase, etc.)
# Para desenvolvimento local, voce pode usar SQLite: file:./dev.db
# Para producao na Vercel, use PostgreSQL (ex: Neon)
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# Auth Secret (gerar uma string aleatoria forte)
AUTH_SECRET="sua-chave-secreta-muito-forte-aqui-minimo-32-caracteres"

# Google AI (Gemini) - Gratuito! Crie em https://aistudio.google.com/app/apikey
# GOOGLE_AI_API_KEY=sua-chave-aqui

# Meta / Instagram / Facebook (opcional)
# META_APP_ID=seu-app-id
# META_APP_SECRET=seu-app-secret

# LinkedIn (opcional)
# LINKEDIN_CLIENT_ID=seu-client-id
# LINKEDIN_CLIENT_SECRET=seu-client-secret

# Twilio - WhatsApp (opcional)
# TWILIO_ACCOUNT_SID=seu-sid
# TWILIO_AUTH_TOKEN=seu-token
# TWILIO_WHATSAPP_NUMBER=+seu-numero

# Resend - Email (opcional)
# RESEND_API_KEY=sua-chave
# FROM_EMAIL=onboarding@resend.dev

NEXT_PUBLIC_APP_URL=https://seu-dominio.vercel.app
