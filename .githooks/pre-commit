#!/bin/sh
# Pre-commit hook to prevent committing secrets
# Install: copy to .git/hooks/pre-commit (no extension) and make executable

set -e

# Patterns to block
PATTERNS='AC[0-9a-f]{32}|AIza[0-9A-Za-z_-]{35}|re_[0-9A-Za-z_-]{20,}|sk-[0-9a-zA-Z]{20,}|AKIA[0-9A-Z]{16}|ghp_[0-9a-zA-Z]{36}|xox[baprs]-[0-9a-zA-Z]{10,}'

if git rev-parse --verify HEAD >/dev/null 2>&1; then
  AGAINST=HEAD
else
  AGAINST=$(git hash-object -t tree /dev/null)
fi

FILES=$(git diff --cached --name-only --diff-filter=ACMR "$AGAINST")

if [ -z "$FILES" ]; then
  exit 0
fi

MATCHES=$(echo "$FILES" | xargs grep -inE "$PATTERNS" 2>/dev/null || true)

if [ -n "$MATCHES" ]; then
  echo "================================================"
  echo "BLOCKED: Potential secrets detected in commit!"
  echo "================================================"
  echo "$MATCHES"
  echo ""
  echo "If these are false positives, use:"
  echo "  git commit --no-verify"
  echo ""
  echo "Never commit real API keys, tokens, or passwords."
  echo "Use .env.local and keep it in .gitignore."
  echo "================================================"
  exit 1
fi

# Also check for .env files (except .env.example)
ENV_FILES=$(echo "$FILES" | grep -E '^\.env($|\.)' | grep -v '^\.env\.example$' || true)
if [ -n "$ENV_FILES" ]; then
  echo "================================================"
  echo "BLOCKED: .env files detected in commit!"
  echo "================================================"
  echo "$ENV_FILES"
  echo ""
  echo "Environment files should NEVER be committed."
  echo "Use .env.example as a template with fake values."
  echo "================================================"
  exit 1
fi

echo "Pre-commit checks passed."
exit 0
