generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String?
  image     String?
  googleId  String?  @unique
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyProfile CompanyProfile?
  posts          Post[]
  clients        Client[]
  trends         Trend[]
  notification   NotificationSettings?
  socialAccounts SocialAccount[]
}

model CompanyProfile {
  id                String  @id @default(uuid())
  userId            String  @unique
  companyName       String
  segment           String
  description       String?
  city              String?
  targetAge         String?
  targetGender      String?
  voice             String?
  words             String?
  avoidWords        String?
  objectives        String?
  frequency         String?
  instagram         Boolean @default(false)
  facebook          Boolean @default(false)
  linkedin          Boolean @default(false)
  whatsapp          String?
  website           String?
  notificationEmail String?
  plan              String  @default("starter")
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id                String  @id @default(uuid())
  userId            String
  title             String
  content           String
  hashtags          String
  type              String
  status            String  @default("pendente")
  date              String
  time              String
  image             String?
  engagement        Int        @default(0)
  socialAccountIds  String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Client {
  id             String @id @default(uuid())
  userId         String
  name           String
  segment        String
  postsThisMonth Int    @default(0)
  pendingPosts   Int    @default(0)
  plan           String @default("starter")
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Trend {
  id            String   @id @default(uuid())
  userId        String
  title         String
  description   String
  urgency       String
  suggestedPost String
  hashtags      String
  expiresIn     String
  niche         String
  approved      Boolean  @default(false)
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationSettings {
  id        String @id @default(uuid())
  userId    String @unique
  whatsapp  Boolean @default(true)
  email     Boolean @default(true)
  trends    Boolean @default(true)
  weekly    Boolean @default(false)
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SocialAccount {
  id           String    @id @default(uuid())
  userId       String
  platform     String
  accountId    String?
  accountName  String?
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  connected    Boolean   @default(true)
  pageType     String?
  scope        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, platform])
}

model IntegrationLog {
  id        String   @id @default(uuid())
  userId    String
  teamId    String?
  event     String
  platform  String?
  status    String
  message   String
  metadata  String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

model NotificationRule {
  id        String   @id @default(uuid())
  userId    String
  eventType String
  channels  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, eventType])
}
