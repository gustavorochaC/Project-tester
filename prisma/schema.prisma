generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("user") // user, admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyProfile CompanyProfile?
  posts          Post[]
  clients        Client[]
  trends         Trend[]
  notification   NotificationSettings?
  socialAccounts SocialAccount[]
}

model CompanyProfile {
  id          String @id @default(uuid())
  userId      String @unique
  companyName String
  segment     String
  description String?
  city        String?
  targetAge   String?
  targetGender String?
  voice       String?
  words       String?
  avoidWords  String?
  objectives  String?
  frequency   String?
  instagram   Boolean @default(false)
  facebook    Boolean @default(false)
  linkedin    Boolean @default(false)
  whatsapp    String?
  plan        String  @default("starter") // starter, pro, agency

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String
  hashtags  String   // JSON stringified array
  type      String   // educacao, promocao, bastidores, depoimento, curiosidade
  status    String   @default("pendente") // pendente, aprovado, reprovado, publicado
  date      String   // YYYY-MM-DD
  time      String   // HH:MM
  image     String?
  engagement Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Client {
  id           String @id @default(uuid())
  userId       String
  name         String
  segment      String
  postsThisMonth Int @default(0)
  pendingPosts   Int @default(0)
  plan         String @default("starter") // starter, pro, agency

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Trend {
  id            String @id @default(uuid())
  userId        String
  title         String
  description   String
  urgency       String // alta, media, baixa
  suggestedPost String
  hashtags      String // JSON stringified array
  expiresIn     String
  niche         String
  approved      Boolean @default(false)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationSettings {
  id        String @id @default(uuid())
  userId    String @unique
  whatsapp  Boolean @default(true)
  email     Boolean @default(true)
  trends    Boolean @default(true)
  weekly    Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SocialAccount {
  id           String   @id @default(uuid())
  userId       String
  platform     String   // instagram, facebook, linkedin
  accountId    String?
  accountName  String?
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  connected    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
}
